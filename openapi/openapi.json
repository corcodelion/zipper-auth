{"openapi":"3.1.0","info":{"title":"Service API","description":"This API exposes endpoints.","contact":{},"license":{"name":"Proprietary"},"version":"v1"},"servers":[],"security":[{"bearerAuth":[]}],"tags":[{"name":"OAuth2","description":"OAuth2 client credentials token endpoint"}],"paths":{"/oauth/token":{"post":{"tags":["OAuth2"],"summary":"Exchange client credentials for an access token","description":"Issues a JWT access token in exchange for valid API client credentials using the client_credentials grant type. Credentials must be provided via HTTP Basic Authentication (Base64-encoded apiKey:apiSecret).","operationId":"token","parameters":[{"name":"Authorization","in":"header","description":"Basic Authentication header (Base64-encoded apiKey:apiSecret)","required":true,"schema":{"type":"string"}},{"name":"grant_type","in":"query","description":"OAuth2 grant type (must be 'client_credentials')","required":true,"schema":{"type":"string"}},{"name":"Accept-Language","in":"header","description":"Language preference for response content. Supported: en, he","required":false,"schema":{"type":"string","default":"en","enum":["en","he"]}}],"responses":{"200":{"description":"Access token issued successfully","content":{"*/*":{"schema":{"$ref":"#/components/schemas/TokenResponse"}}}},"400":{"description":"Unsupported grant type"},"401":{"description":"Invalid client credentials"},"500":{"description":"Internal server error"}}}}},"components":{"schemas":{"TokenResponse":{"type":"object","properties":{"access_token":{"type":"string"},"token_type":{"type":"string"},"expires_in":{"type":"integer","format":"int32"}}}},"securitySchemes":{"bearerAuth":{"type":"http","scheme":"bearer","bearerFormat":"JWT"}}}}